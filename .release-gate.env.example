A_EMAIL=operator@example.com
A_PASSWORD=change-me-operator-password
B_EMAIL=customer@example.com
B_PASSWORD=change-me-customer-password
SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace_me
# Optional: override default project URL
# SUPABASE_URL=https://your-project-ref.supabase.co
# Optional: full 1-6 box cycle in pre-push gate (default is 0 for faster checks)
# RUN_SUPABASE_BOX_CYCLE=0
# Optional: quick activate/countdown flow in pre-push gate (default is 0 to avoid flaky box occupancy failures)
# RUN_SUPABASE_QUICK_FLOW_CHECK=0
# SUPABASE_QUICK_FLOW_BOX_ID=1
# SUPABASE_QUICK_FLOW_AMOUNT=1
# Pre-push enforces UAT backlog gate with open critical/high fail.
# RUN_SUPABASE_UAT_BACKLOG_GATE is forced to 1 in .githooks/pre-push.
# Optional: legal/support live URL check (default 0, enable for pre-release validation)
# RUN_LEGAL_SUPPORT_CHECK=1
# LEGAL_PRIVACY_URL=https://www.glanzpunkt-wahlstedt.de/datenschutz
# LEGAL_IMPRINT_URL=https://www.glanzpunkt-wahlstedt.de/impressum
# SUPPORT_EMAIL=support@glanzpunkt-wahlstedt.de
# Optional: customer top-up feature flag (default true in app build)
# CUSTOMER_TOP_UP_ENABLED=true
